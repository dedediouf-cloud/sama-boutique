generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  shopName  String
  shopSlug  String   @unique
  phone     String?
  isBlocked Boolean  @default(false)
  subscriptionAmount Float    @default(0)
  subscriptionStatus String   @default("pending") // pending, paid, overdue
  subscriptionDueDate DateTime?
  lastPaidAt          DateTime?
  billingInterval    String   @default("monthly") // monthly, annual
  referralCode       String   @unique
  referredById     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products              Product[]
  customers             Customer[]
  sales                 Sale[]
  reservations          Reservation[]
  employees             Employee[]
  stockEntries          StockEntry[]
  deliveries            Delivery[]
  promotions            Promotion[]
  suppliers             Supplier[]
  supplierOrders        SupplierOrder[]
  inventoryCounts       InventoryCount[]
  subscriptionPayments  SubscriptionPayment[]
  referralRewards       ReferralReward[] @relation("ReferrerRewards")
  rewardsFrom           ReferralReward[] @relation("ReferredRewards")
  referredBy            User?   @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referralsMade         User[]  @relation("UserReferrals")
}

model StockEntry {
  id        String   @id @default(cuid())
  quantity  Int
  note      String?
  createdAt DateTime @default(now())

  productId String
  product   Product  @relation(fields: [productId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model Employee {
  id        String   @id @default(cuid())
  name      String
  email     String
  password  String
  role      String   @default("seller") // admin, seller
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  sales     Sale[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  quantity    Int      @default(0)
  lowStock    Int      @default(5)
  category    String?
  imageUrl    String?
  supplierId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  supplier Supplier? @relation(fields: [supplierId], references: [id])

  saleItems    SaleItem[]
  stockEntries StockEntry[]
  inventoryCounts InventoryCount[]
}

model Customer {
  id             String    @id @default(cuid())
  name           String
  phone          String?
  address        String?
  email          String?
  fidelityPoints Int       @default(0)
  notes          String?
  dateOfBirth    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  sales         Sale[]
  reservations  Reservation[]
}

model Promotion {
  id          String    @id @default(cuid())
  code        String?   @unique
  name        String
  type        String    // percentage, fixed_amount
  value       Float
  minAmount   Float?
  startDate   DateTime?
  endDate     DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  sales Sale[]
}

model Sale {
  id                  String   @id @default(cuid())
  total               Float
  discount            Float    @default(0)
  finalTotal          Float
  paymentMethod       String?  @default("cash") // cash, orange_money, wave
  paymentStatus       String?  @default("pending") // pending, paid, failed
  paymentRef          String?
  deliveryType        String?  @default("pickup") // pickup, delivery
  earnedFidelityPoints Int     @default(0)
  createdAt           DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  promotionId String?
  promotion   Promotion? @relation(fields: [promotionId], references: [id])

  items         SaleItem[]
  transactions  PaymentTransaction[]
  delivery      Delivery?
}

model PaymentTransaction {
  id        String   @id @default(cuid())
  provider  String   // orange_money, wave
  amount    Float
  reference String?
  status    String   @default("pending") // pending, paid, failed, cancelled
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id])
}

model Delivery {
  id            String   @id @default(cuid())
  status        String   @default("pending") // pending, preparing, shipped, delivered, cancelled
  address       String
  phone         String?
  notes         String?
  deliveryDate  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  saleId String @unique
  sale   Sale   @relation(fields: [saleId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model SaleItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Float

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  orders   SupplierOrder[]
  products Product[]   // Relation inverse obligatoire (pour Product.supplier)
}

model SupplierOrder {
  id           String   @id @default(cuid())
  status       String   @default("pending") // pending, received, cancelled
  total        Float
  orderDate    DateTime @default(now())
  receivedDate DateTime?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items SupplierOrderItem[]
}

model SupplierOrderItem {
  id          String  @id @default(cuid())
  productName String
  quantity    Int
  unitPrice   Float
  productId   String?

  supplierOrderId String
  supplierOrder   SupplierOrder @relation(fields: [supplierOrderId], references: [id])
}

model Reservation {
  id            String   @id @default(cuid())
  productId     String?
  productName   String
  customerName  String
  customerPhone String?
  quantity      Int      @default(1)
  status        String   @default("pending") // pending, confirmed, cancelled
  message       String?
  createdAt     DateTime @default(now())

  userId String
  user   User     @relation(fields: [userId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
}

model SuperAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryCount {
  id            String   @id @default(cuid())
  countedQty    Int
  systemQty     Int
  difference    Int
  note          String?
  countedAt     DateTime @default(now())
  createdAt     DateTime @default(now())

  productId String
  product   Product  @relation(fields: [productId], references: [id])

  userId String
  user   User     @relation(fields: [userId], references: [id])
}

model SubscriptionPayment {
  id            String   @id @default(cuid())
  amount        Float
  discount      Float    @default(0)
  finalAmount   Float
  promotionId   String?
  promotionName String?
  periodStart   DateTime
  periodEnd     DateTime
  paidAt        DateTime @default(now())

  userId String
  user   User     @relation(fields: [userId], references: [id])
}

model SubscriptionPromotion {
  id              String   @id @default(cuid())
  name            String
  code            String?  @unique
  discountPercent Int?     // ex: 20 pour 20%
  discountAmount  Float?     // ex: 1000
  monthsFree      Int        @default(0)
  active          Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model GlobalSettings {
  id                         String   @id @default("default")
  annualSubscriptionDiscount Float    @default(0)
  referralRewardMonths       Int      @default(1)
  defaultMonthlyAmount       Float    @default(10000)
  updatedAt                  DateTime @updatedAt
}

model ReferralReward {
  id            String   @id @default(cuid())
  referrerId    String
  referredId    String
  monthsGranted Int
  createdAt     DateTime @default(now())

  referrer      User     @relation("ReferrerRewards", fields: [referrerId], references: [id], onDelete: Cascade)
  referred      User     @relation("ReferredRewards", fields: [referredId], references: [id], onDelete: Cascade)
}
